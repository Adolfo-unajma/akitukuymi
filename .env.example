# =============================================================================
# Configuración de Akitukuymi — copia este archivo como .env y completa
# =============================================================================
# 1. Copia este archivo:  cp .env.example .env
# 2. Completa los valores reales abajo
# 3. Ejecuta:  node .guardian/packages/net-hooks/index.js --env
#    para regenerar src/environments/environment.ts con los valores.
# =============================================================================

# ── Supabase ──────────────────────────────────────────────────────────────────
# URL del proyecto (Dashboard → Settings → API → Project URL)
SUPABASE_URL=
# Llave anónima / publishable (Dashboard → Settings → API → anon public)
SUPABASE_ANON_KEY=

# ── n8n chatbot ───────────────────────────────────────────────────────────────
# Webhook del flujo n8n (opcional; vacío = respuestas demo)
N8N_CHAT_WEBHOOK_URL=

# ── Contacto ──────────────────────────────────────────────────────────────────
CONTACTO_WHATSAPP=
CONTACTO_EMAIL=
CONTACTO_UBICACION=
CONTACTO_INSTAGRAM=
CONTACTO_FACEBOOK=
CONTACTO_TIKTOK=
